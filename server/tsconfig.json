{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "noImplicitAny": false,
    "skipLibCheck": true,
    "strict": true,
    "useUnknownInCatchVariables": false,
    "noPropertyAccessFromIndexSignature": false,
    "downlevelIteration": true
  },
  "include": ["src"],
  "exclude": ["src/__tests__"]
}
